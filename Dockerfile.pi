# syntax=docker/dockerfile:1
#
# Pi coding agent (pi.dev) runner, built on the agentic-dev-base.
# Build the base first:   docker build -t agentic-dev-base:latest .
#
# Codebase + Pi config are bind-mounted at RUN time (not baked in):
#   - host repo  -> /work
#   - host ~/.pi -> /home/dev/.pi
#
# UID/GID are build args so files written into the mounted config/repo
# stay owned by your host user.

FROM agentic-dev-base:latest

ARG UID=1000
ARG GID=1000

# Pi CLI (npm). --ignore-scripts per the upstream installer recommendation.
# codegraph + biome (for the AFT plugin) ship alongside; all global bins land on
# PATH (/usr/local/bin via the base node setup). biome is installed WITHOUT
# --ignore-scripts so its postinstall can fetch the platform binary.
RUN set -eux; \
    npm install -g --ignore-scripts @earendil-works/pi-coding-agent; \
    npm install -g @colbymchenry/codegraph @biomejs/biome; \
    npm cache clean --force; \
    rm -rf /root/.npm /tmp/*; \
    pi --version; \
    command -v codegraph; \
    command -v biome

# `pi install <plugin>` runs plain `npm install`, and npm 11 added an
# allow-scripts gate: any dependency with install/postinstall scripts (e.g.
# better-sqlite3, esbuild) not on the allowlist triggers a `npm approve-scripts`
# prompt on every install. The container is the sandbox here, and Pi plugins run
# arbitrary code regardless ("packages run with full system access"), so drop the
# gate and let install scripts run unattended.
ENV NPM_CONFIG_DANGEROUSLY_ALLOW_ALL_SCRIPTS=true

# Non-root user whose UID/GID match the host owner of the mounted files.
RUN set -eux; \
    groupadd -g "${GID}" dev 2>/dev/null || true; \
    useradd -m -u "${UID}" -g "${GID}" -s /bin/bash dev

USER dev
ENV HOME=/home/dev

# Redirect XDG data + config under the bind-mounted Pi config dir so plugins that
# store state in $XDG_DATA_HOME (default ~/.local/share) or read config from
# $XDG_CONFIG_HOME (default ~/.config) — both ephemeral here, only ~/.pi is
# mounted — persist across containers. e.g. magic-context reads its config from
# ~/.pi/config/cortexkit/magic-context.jsonc and writes its DB to
# ~/.pi/share/cortexkit instead of ~/.config and ~/.local/share.
ENV XDG_DATA_HOME=/home/dev/.pi/share
ENV XDG_CONFIG_HOME=/home/dev/.pi/config

WORKDIR /work

# pi is the entrypoint; extra args from `docker run` are appended.
ENTRYPOINT ["pi"]

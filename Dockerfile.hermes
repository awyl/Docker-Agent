# syntax=docker/dockerfile:1
#
# Hermes agent (NousResearch) runner, built on the agentic-dev-base.
# Build the base first:   docker build -t agentic-dev-base:latest .
#
# Codebase + Hermes config are bind-mounted at RUN time (not baked in):
#   - host repo      -> /work
#   - host ~/.hermes -> /home/dev/.hermes
#
# UID/GID are build args so files written into the mounted config/repo
# stay owned by your host user.

FROM agentic-dev-base:latest

ARG UID=1000
ARG GID=1000

# Hermes pin: clone tag/branch to install. Defaults to the default branch.
ARG HERMES_REF=main

# Hermes is a Python app. Install it into an isolated venv at /opt/hermes and
# symlink the launcher onto the global PATH. Kept OUT of ~/.hermes on purpose:
# that dir is the runtime-mounted config and would shadow anything installed
# there. uv (from the base) fetches Python 3.11 — the `.[all]` voice deps are
# not yet 3.13-clean. ffmpeg is needed for the voice/TTS toolset.
#
# UV_PYTHON_INSTALL_DIR puts the managed interpreter under /opt (world-
# traversable) instead of the default /root/.local/share (mode 700), so the
# non-root `dev` user can actually exec the venv's python at runtime.
ENV UV_PYTHON_INSTALL_DIR=/opt/uv/python
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ffmpeg; \
    rm -rf /var/lib/apt/lists/*; \
    git clone --depth 1 --branch "${HERMES_REF}" \
        https://github.com/NousResearch/hermes-agent.git /opt/hermes; \
    uv venv /opt/hermes/.venv --python 3.11; \
    VIRTUAL_ENV=/opt/hermes/.venv uv pip install --no-cache "/opt/hermes/.[all]"; \
    ln -s /opt/hermes/.venv/bin/hermes /usr/local/bin/hermes; \
    chmod -R a+rX /opt/uv/python; \
    rm -rf /root/.cache /tmp/*; \
    test -x /usr/local/bin/hermes

# Non-root user whose UID/GID match the host owner of the mounted files.
RUN set -eux; \
    groupadd -g "${GID}" dev 2>/dev/null || true; \
    useradd -m -u "${UID}" -g "${GID}" -s /bin/bash dev

USER dev
ENV HOME=/home/dev
WORKDIR /work

# hermes is the entrypoint; bare `hermes` starts the interactive CLI.
# Extra args from `docker run` are appended.
ENTRYPOINT ["hermes"]
